# ────────────────────────────────────────────
# PLOS Backend Configuration (.env.example)
# Copy to .env and fill in your values
# ────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Database
DB_PATH=plos.db

# JWT
JWT_SECRET=plos-secret-jwt-2026

# Google Gemini API
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AQ.your_gemini_key_here

# Google OAuth (for Gmail integration)
# Setup at: https://console.cloud.google.com/
# Redirect URI: https://your-domain/api/gmail/callback
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Frontend
FRONTEND_URL=https://finance-os-676.pages.dev
